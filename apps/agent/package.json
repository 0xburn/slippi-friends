{
  "name": "@slippi-friends/agent",
  "version": "0.1.66",
  "private": true,
  "description": "friendlies - a friends list for melee",
  "author": "Lucky 7s Melee LLC",
  "repository": "https://github.com/0xburn/friendlies",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -n tsc,vite,electron \"tsc -w --preserveWatchOutput\" \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "build": "tsc && vite build && electron-builder",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:linux": "tsc && vite build && electron-builder --linux",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@slippi/slippi-js": "^9.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "chokidar": "^4.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "find-process": "^1.4.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "31.7.7",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.1",
    "wait-on": "^8.0.0"
  }
}
